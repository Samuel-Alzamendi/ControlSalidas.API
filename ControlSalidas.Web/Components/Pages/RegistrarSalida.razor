@page "/RegistrarSalida"
@rendermode InteractiveServer

@using ControlSalidas.Shared.Models
@using ControlSalidas.Shared.Request;
@inject HttpClient Http

<h3>RegistrarSalida</h3>

<PageTitle>Registrar salida</PageTitle>

<div class="mb-3">
    <label>Fecha salida</label>
    <InputDate @bind-Value="nuevaSalida.FechaSalida" />
</div>

<div class="mb-3">
    <label>Fecha llegada</label>
    <InputDate @bind-Value="nuevaSalida.FechaLlegada" />
</div>

<h5>Funcionarios</h5>
@if (!funcionariosConfirmados)
{
    @if (funcionarios.Count == 0)
    {
        <p>No hay funcionarios</p>
    }
    else
    {
        @foreach (var funcionario in funcionarios)
        {
            <div>
                <input type="checkbox"
                       @bind="funcionariosSeleccionados[funcionario.Id]" />
                @funcionario.Nombre
            </div>
        }
    }
}
else
{
    <div class="alert alert-success">
        Funcionarios confirmados
    </div>
}


<button class="btn btn-secondary"
        @onclick="ConfirmarFuncionarios">
    Confirmar funcionarios
</button>

<h5>Hospitales</h5>

@if (!hospitalesConfirmados)
{
    @foreach (var hospital in hospitales)
    {
        <div>
            <input type="checkbox"
                   @bind="hospitalesSeleccionados[hospital.Id]" />

            @hospital.Nombre
        </div>
    }

    <button class="btn btn-secondary"
            @onclick="ConfirmarHospitales">
        Confirmar hospitales
    </button>
}
else
{
    <div class="alert alert-success">
        Hospitales confirmados
    </div>
}

@if (funcionariosConfirmados && hospitalesConfirmados && !horariosGenerados)
{
    <button class="btn btn-warning"
            @onclick="GenerarHorarios">
        Generar horarios
    </button>
}

@if (horariosGenerados)
{
    @for (int i = 0; i < horariosDias.Count; i++)
    {
        <div class="border p-2 mb-2">

            <strong>
                Día @(i + 1)
            </strong>

            <br />

            <label>Desde</label>
            <input type="time"
                   @bind="horariosDias[i].Desde" />

            <label>Hasta</label>
            <input type="time"
                   @bind="horariosDias[i].Hasta" />

        </div>
    }
}

