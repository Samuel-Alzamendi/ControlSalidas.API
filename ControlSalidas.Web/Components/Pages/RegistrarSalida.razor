</button> *@














@code {
    public class HorarioDiaViewModel
    {
        public TimeOnly Desde { get; set; } = new(7, 0);
        public TimeOnly Hasta { get; set; } = new(13, 0);
    }

    private RegistrarSalidaRequest nuevaSalida = new()
    {
        FechaSalida = DateOnly.FromDateTime(DateTime.Today),
        FechaLlegada = DateOnly.FromDateTime(DateTime.Today)
    };

    List<SalidaFuncionario>? salidaFuncionarios;
    List<Salida>? salidas;
    List<Funcionario> funcionarios = new();
    private List<Hospital> hospitales = new();
    private Dictionary<int, bool> funcionariosSeleccionados = new();
    private Dictionary<int, bool> hospitalesSeleccionados = new();
    private List<HorarioDiaViewModel> horariosDias = new();

    private bool funcionariosConfirmados = false;
    private bool horariosGenerados = false;
    private bool hospitalesConfirmados = false;
    private string mensajeError = "";
    private void ConfirmarFuncionarios()
    {
        if (!funcionariosSeleccionados.Any(x => x.Value))
        {
            mensajeError = "Debe seleccionar al menos un funcionario.";
            return;
        }

        mensajeError = "";
        funcionariosConfirmados = true;
    }

    private void ConfirmarHospitales()
    {
        if (!hospitalesSeleccionados.Any(x => x.Value))
        {
            mensajeError = "Debe seleccionar al menos un hospital.";
            return;
        }

        mensajeError = "";
        hospitalesConfirmados = true;
    }

    private void GenerarHorarios()
    {

            horariosDias.Clear();

            horariosGenerados = true;

            int dias =
                nuevaSalida.FechaLlegada.DayNumber -
                nuevaSalida.FechaSalida.DayNumber + 1;

            for (int i = 0; i < dias; i++)
            {
                horariosDias.Add(new HorarioDiaViewModel());
            }
        

    }

    private async Task RegistrarSalidaEvent()
    {
        nuevaSalida.FuncionariosIds =
            funcionariosSeleccionados
                .Where(x => x.Value)
                .Select(x => x.Key)
                .ToList();

        nuevaSalida.HospitalesIds =
            hospitalesSeleccionados
                .Where(x => x.Value)
                .Select(x => x.Key)
                .ToList();

        nuevaSalida.HorariosDesdeQueHora =
            horariosDias
                .Select(x => x.Desde)
                .ToArray();

        nuevaSalida.HorariosHastaQueHora =
            horariosDias
                .Select(x => x.Hasta)
                .ToArray();

        var response = await Http.PostAsJsonAsync(
            "api/Funcionarios/Registrar_salida",
            nuevaSalida);

        var contenido = await response.Content.ReadAsStringAsync();

        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine($"ERROR: {response.StatusCode}");
            Console.WriteLine(contenido);
            return;
        }

        Console.WriteLine("OK: salida registrada");
    }

    protected override async Task OnInitializedAsync()
    {
        salidaFuncionarios = await Http.GetFromJsonAsync<List<SalidaFuncionario>>(
            "api/Funcionarios/Obtener_Salidas_Funcionarios");

        salidas = await Http.GetFromJsonAsync<List<Salida>>(
            "api/Funcionarios/Obtener_Salidas");

        hospitales = await Http.GetFromJsonAsync<List<Hospital>>(
            "api/Funcionarios/Obtener_Hospitales");

        funcionarios = await Http.GetFromJsonAsync<List<Funcionario>>(
            "api/Funcionarios/Obtener_Funcionarios");

        foreach (var f in funcionarios)
            funcionariosSeleccionados[f.Id] = false;

        foreach (var h in hospitales)
            hospitalesSeleccionados[h.Id] = false;

    }

}
