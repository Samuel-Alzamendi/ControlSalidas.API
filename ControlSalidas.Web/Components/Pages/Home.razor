@page "/"

@using ControlSalidas.Shared.Models
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<h3>Funcionarios</h3>

@if (funcionarios == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>CI</th>
                <th>Nombre</th>
                <th>Noches</th>
                <th>Días fuera</th>
                <th>Cantidad de salidas</th>
                <th>Pernotes este mes</th>
                <th>Viaticos este mes</th>
                <th>Importe total en el mes</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var f in funcionarios)
            {
                
                    var resumen = resumenesMensuales?
                    .FirstOrDefault(r =>
                    r.FuncionarioId == f.Id &&
                    r.Anio == DateTime.Now.Year &&
                    r.Mes == DateTime.Now.Month);

                    <tr>
                        <td>@f.Id</td>
                        <td>@f.Ci</td>
                        <td>@f.Nombre</td>
                        <td>@f.Noches</td>
                        <td>@f.DiasFuera</td>
                        <td>@f.CantidadSalidas</td>
                        <td>$ @(resumen?.ImportePernoctes ?? 0)</td>
                        <td>$ @(resumen?.Viaticos ?? 0)</td>
                        <td>$ @(resumen?.ImporteTotal ?? 0)</td>
                    </tr>
                
            }
        </tbody>
    </table>
}

<h3>Salidas</h3>

@if (salidas == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Fecha de salida</th>
                <th>Fecha de llegada</th>
                <th>Estado</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in salidas)
            {
                <tr>
                    <td>@s.FechaSalida</td>
                    <td>@s.FechaLlegada</td>
                    <td>
                        @if (s.Estado == "En curso")
                        {
                            <span class="badge bg-success">@s.Estado</span>
                        }
                        else if (s.Estado == "Finalizado")
                        {
                            <span class="badge bg-secondary">@s.Estado</span>
                        }
                        else if (s.Estado == "Para salir")
                        {
                            <span class="badge bg-primary">@s.Estado</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    List<Funcionario>? funcionarios;
    List<Salida>? salidas;
    List<SalidaFuncionario>? salidaFuncionarios;
    List<ResumenMensualFuncionario>? resumenesMensuales;

    protected override async Task OnInitializedAsync()
    {
        funcionarios = await Http.GetFromJsonAsync<List<Funcionario>>(
            "api/Funcionarios/Obtener_funcionarios");

        salidas = await Http.GetFromJsonAsync<List<Salida>>(
            "api/Funcionarios/Obtener_salidas");

        resumenesMensuales = await Http.GetFromJsonAsync<List<ResumenMensualFuncionario>>(
            "api/Funcionarios/Obtener_resumen_mensual");
    }
}
